{{- if eq .chezmoi.os "darwin" -}}
#!/bin/bash
set -euo pipefail

echo "==> Installing Oh My Zsh and external plugins"

# Install Oh My Zsh non-interactively if missing.
ZSH="${ZSH:-$HOME/.oh-my-zsh}"
if [[ ! -d "$ZSH" ]]; then
  echo "Oh My Zsh not found. Installing..."
  RUNZSH=no CHSH=no KEEP_ZSHRC=yes \
    sh -c "$(curl -fsSL https://raw.githubusercontent.com/ohmyzsh/ohmyzsh/master/tools/install.sh)"
fi

ZSH_CUSTOM="${ZSH_CUSTOM:-$ZSH/custom}"

# Clone or update each external plugin defined in packages.yaml.
{{- range .packages.omz }}
PLUGIN_DIR="$ZSH_CUSTOM/plugins/{{ .name }}"
if [[ -d "$PLUGIN_DIR/.git" ]]; then
  echo "Updating {{ .name }}..."
  git -C "$PLUGIN_DIR" pull --ff-only --quiet
else
  echo "Cloning {{ .name }}..."
  git clone --depth=1 --quiet {{ .url }} "$PLUGIN_DIR"
fi
{{- end }}

echo "==> Oh My Zsh plugins ready"
{{- end -}}
