{{- if eq .chezmoi.os "darwin" -}}
#!/bin/bash
set -euo pipefail

echo "==> Installing packages from .chezmoidata/packages.yaml"

# Generate a Brewfile on the fly from packages.yaml and pipe it to brew bundle.
# Keeping the Brewfile in stdin keeps the source of truth in YAML.
brew bundle --no-lock --file=/dev/stdin <<EOF
{{- range .packages.brews }}
brew "{{ . }}"
{{- end }}
{{ range .packages.casks }}
cask "{{ . }}"
{{- end }}
EOF

echo "==> Packages installed"
{{- end -}}
